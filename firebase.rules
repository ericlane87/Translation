rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRoomParticipant(roomId) {
      return isSignedIn() && exists(
        /databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)
      );
    }

    match /users/{uid} {
      allow read, update, create: if isOwner(uid);

      match /contacts/{contactId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /callIds/{callId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /calls/{callDocId} {
      allow create: if isSignedIn() && request.resource.data.callerUid == request.auth.uid;
      allow read, update: if isSignedIn() && (
        resource.data.callerUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );

      match /{candidateCollection}/{candidateDoc} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/calls/$(callDocId)).data.callerUid == request.auth.uid ||
          get(/databases/$(database)/documents/calls/$(callDocId)).data.receiverUid == request.auth.uid
        );
      }
    }

    match /rooms/{roomId} {
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow read: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.createdByUid == request.auth.uid;

      match /participants/{participantUid} {
        allow read: if isSignedIn() && (
          participantUid == request.auth.uid ||
          isRoomParticipant(roomId)
        );
        allow create: if isSignedIn() &&
          participantUid == request.auth.uid &&
          request.resource.data.uid == request.auth.uid;
        allow update, delete: if isSignedIn() && (
          participantUid == request.auth.uid ||
          get(/databases/$(database)/documents/rooms/$(roomId)).data.createdByUid == request.auth.uid
        );
      }

      match /signals/{signalId} {
        allow create: if isRoomParticipant(roomId) &&
          request.resource.data.fromUid == request.auth.uid;
        allow read, delete: if isSignedIn() && resource.data.toUid == request.auth.uid;
      }
    }
  }
}
