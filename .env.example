OPENAI_API_KEY=your_openai_api_key_here
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id
# Optional if not using GOOGLE_APPLICATION_CREDENTIALS.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Comma-separated allowlist for production web origins.
# CORS_ORIGIN=https://app.example.com,https://www.example.com
# Optional distributed rate limit store.
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# TURN (coturn REST auth / static-auth-secret model)
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# TURN_REALM=turn.example.com
# TURN_SHARED_SECRET=replace_with_static_auth_secret
# TURN_TTL_SEC=3600
PORT=4010
